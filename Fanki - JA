<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ファンキ - JA | OFFICIAL SITE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Noto+Sans+JP:wght@400;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --neon-pink: #ff00ff;
            --toxic-green: #39ff14;
            --acid-yellow: #f4ff00;
            --blood-red: #ff0000;
        }

        body {
            background-color: #000;
            color: #fff;
            font-family: 'Noto Sans JP', sans-serif;
            overflow-x: hidden;
        }

        .punk-font {
            font-family: 'Oswald', sans-serif;
            text-transform: uppercase;
            letter-spacing: -0.05em;
        }

        /* リソグラフ風テクスチャのオーバーレイ */
        .risograph-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 9999;
            opacity: 0.08;
            background-image: url('https://www.transparenttextures.com/patterns/stardust.png');
        }

        .section-title {
            font-size: 5rem;
            line-height: 0.8;
            margin-bottom: 2rem;
            color: var(--neon-pink);
            -webkit-text-stroke: 1px white;
            text-shadow: 4px 4px 0px var(--toxic-green);
        }

        .marquee {
            white-space: nowrap;
            overflow: hidden;
            background: var(--acid-yellow);
            color: #000;
            padding: 10px 0;
            font-weight: 900;
        }

        .marquee-content {
            display: inline-block;
            animation: marquee 20s linear infinite;
        }

        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        .grain-btn {
            background: var(--neon-pink);
            color: #fff;
            padding: 1rem 2rem;
            font-weight: 900;
            border: none;
            clip-path: polygon(5% 0%, 100% 0%, 95% 100%, 0% 100%);
            transition: all 0.2s;
        }

        .grain-btn:hover {
            background: var(--toxic-green);
            color: #000;
            cursor: pointer;
        }

        .misreg-text {
            position: relative;
            display: inline-block;
        }
        .misreg-text::before {
            content: attr(data-text);
            position: absolute;
            left: 2px;
            top: 2px;
            color: var(--neon-pink);
            z-index: -1;
            opacity: 0.7;
        }

        .news-card {
            background: #111;
            border: 4px solid #fff;
            padding: 2rem;
            transform: rotate(-1deg);
            transition: all 0.2s;
            position: relative;
        }
        .news-card:hover {
            transform: rotate(0deg) scale(1.02);
            border-color: var(--toxic-green);
        }
        .news-date {
            background: var(--blood-red);
            color: #fff;
            padding: 2px 10px;
            font-weight: 900;
            display: inline-block;
            margin-bottom: 1rem;
        }

        /* Gemini API用スタイル */
        .gemini-tool {
            background: #111;
            border: 4px solid var(--acid-yellow);
            padding: 2rem;
            margin-top: 2rem;
        }

        .punk-input {
            background: transparent;
            border: 2px solid #fff;
            color: #fff;
            padding: 10px;
            width: 100%;
            margin-bottom: 1rem;
            font-weight: bold;
        }

        .punk-input:focus {
            outline: none;
            border-color: var(--toxic-green);
        }

        #lyrics-output {
            white-space: pre-wrap;
            background: #222;
            padding: 1.5rem;
            border-left: 8px solid var(--neon-pink);
            font-style: italic;
        }

        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="risograph-overlay"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 w-full z-50 p-6 mix-blend-difference">
        <div class="flex justify-between items-center">
            <h1 class="punk-font text-4xl font-black italic tracking-tighter">FUNKI - JA</h1>
            <div class="space-x-8 text-xl font-bold">
                <a href="#news" class="hover:text-[var(--toxic-green)]">NEWS</a>
                <a href="#music" class="hover:text-[var(--neon-pink)]">MUSIC</a>
                <a href="#about" class="hover:text-[var(--acid-yellow)]">ABOUT</a>
                <a href="#ai-tool" class="hover:text-white bg-red-600 px-2">✨AI LAB</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="h-screen flex items-center justify-center relative overflow-hidden bg-[#39ff14]">
        <div class="absolute inset-0 opacity-40 grayscale flex items-center justify-center">
             <div class="text-[20rem] font-black leading-none select-none opacity-20">FUNKI</div>
        </div>
        
        <div class="z-10 text-center px-4">
            <div class="misreg-text" data-text="ファンキ - JA">
                <h2 class="punk-font text-8xl md:text-[12rem] font-black text-black leading-none drop-shadow-xl">
                    FUNKI<br>- JA
                </h2>
            </div>
            <p class="text-2xl mt-4 font-bold text-black bg-white inline-block px-4 py-2 transform -rotate-1">
                LOUD. RAW. REAL.
            </p>
            <div class="mt-12">
                <button class="grain-btn text-2xl">LATEST RELEASE</button>
            </div>
        </div>
    </header>

    <!-- AI Tools Section -->
    <section id="ai-tool" class="py-24 px-6 bg-black border-y-8 border-white">
        <div class="max-w-4xl mx-auto">
            <h2 class="section-title punk-font">✨AI PUNK LAB</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Lyrics Generator -->
                <div class="gemini-tool">
                    <h3 class="text-2xl font-black mb-4 uppercase">✨ 衝動を歌詞にしろ</h3>
                    <p class="text-sm text-gray-400 mb-4">今の怒りや感情をキーワードで叩き込め。AIがパンクな歌詞を吐き出す。</p>
                    <input type="text" id="lyrics-input" class="punk-input" placeholder="例：退屈な日常、腐った政治...">
                    <button onclick="generateLyrics()" id="lyrics-btn" class="grain-btn w-full">✨ 歌詞を生成する</button>
                    <div id="lyrics-output" class="mt-6 hidden"></div>
                </div>

                <!-- Chat Bot -->
                <div class="gemini-tool border-toxic-green" style="border-color: var(--toxic-green);">
                    <h3 class="text-2xl font-black mb-4 uppercase">✨ ファンキと対話しろ</h3>
                    <p class="text-sm text-gray-400 mb-4">ファンキの哲学についてAIに問え。媚びない返答が来る。</p>
                    <input type="text" id="chat-input" class="punk-input" placeholder="例：音楽とは何だ？">
                    <button onclick="chatWithFunki()" id="chat-btn" class="grain-btn w-full" style="background: var(--toxic-green); color: black;">✨ 問いかける</button>
                    <div id="chat-output" class="mt-6 hidden p-4 border border-white"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- News Section -->
    <section id="news" class="py-24 px-6 max-w-6xl mx-auto">
        <h2 class="section-title punk-font">NEWS</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="news-card">
                <div class="news-date">2026.03.17</div>
                <h3 class="text-4xl font-black mb-4">ファンキ！出動！</h3>
                <p class="text-xl leading-relaxed">
                    ファンキ、出動したぞ！これからほぼ毎日音楽を投稿するぞ！
                </p>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="py-24 px-6 relative">
        <div class="max-w-4xl mx-auto text-center">
            <h2 class="section-title punk-font">WE ARE FUNKI - JA</h2>
            <p class="text-3xl md:text-5xl font-black leading-tight mb-8">
                「綺麗事はいらない。<br>
                <span class="text-[var(--toxic-green)]">歪んだ音</span>と<span class="text-[var(--neon-pink)]">真実</span>だけを。」
            </p>
            <p class="text-xl text-zinc-400 leading-relaxed">
                2026年結成。既存の音楽シーンの枠組みを破壊し、リソグラフの粗い質感のように不完全で、かつ純粋な衝動を音に変換する。
                我々の音楽は、誰かに評価されるためのものではなく、我々が生きるための咆哮である。
            </p>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-black border-t-8 border-[var(--blood-red)] py-12 px-6">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
            <div>
                <p class="punk-font text-5xl font-black">FUNKI - JA</p>
                <p class="text-zinc-600 mt-2">© 2026 FUNKI - JA / INDEPENDENT RECORDS</p>
            </div>
            <div class="flex gap-6">
                <a href="#" class="text-3xl hover:text-[var(--neon-pink)]">INSTAGRAM</a>
                <a href="#" class="text-3xl hover:text-[var(--toxic-green)]">X</a>
                <a href="#" class="text-3xl hover:text-[var(--acid-yellow)]">YOUTUBE</a>
            </div>
        </div>
    </footer>

    <script>
        const apiKey = ""; // APIキーは実行環境により提供されます

        async function callGemini(prompt, systemInstruction) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text: prompt }] }],
                systemInstruction: { parts: [{ text: systemInstruction }] }
            };

            let delay = 1000;
            for (let i = 0; i < 5; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    if (!response.ok) throw new Error('API Error');
                    const data = await response.json();
                    return data.candidates?.[0]?.content?.parts?.[0]?.text;
                } catch (error) {
                    if (i === 4) throw error;
                    await new Promise(resolve => setTimeout(resolve, delay));
                    delay *= 2;
                }
            }
        }

        async function generateLyrics() {
            const input = document.getElementById('lyrics-input').value;
            const output = document.getElementById('lyrics-output');
            const btn = document.getElementById('lyrics-btn');
            if (!input) return;

            btn.disabled = true;
            btn.innerHTML = '<span class="loading-spinner"></span>';
            output.classList.add('hidden');

            try {
                const systemPrompt = "あなたは日本のパンクバンド「ファンキ - JA」の作詞担当です。ユーザーの入力したキーワードを元に、過激で、既存の価値観を破壊するような、荒々しいパンクの歌詞を生成してください。短く、衝撃的な言葉を選んでください。";
                const lyrics = await callGemini(input, systemPrompt);
                output.innerText = lyrics;
                output.classList.remove('hidden');
            } catch (error) {
                output.innerText = "エラー：衝動が強すぎてサーバーが壊れた。後でまたやれ。";
                output.classList.remove('hidden');
            } finally {
                btn.disabled = false;
                btn.innerText = "✨ 歌詞を生成する";
            }
        }

        async function chatWithFunki() {
            const input = document.getElementById('chat-input').value;
            const output = document.getElementById('chat-output');
            const btn = document.getElementById('chat-btn');
            if (!input) return;

            btn.disabled = true;
            btn.innerHTML = '<span class="loading-spinner"></span>';
            output.classList.add('hidden');

            try {
                const systemPrompt = "あなたは日本のパンクバンド「ファンキ - JA」のリーダーです。口調は荒く、パンク精神に溢れています。音楽、社会、自由について熱く語りますが、媚びるような態度は一切見せません。「綺麗事はいらない」が信条です。回答は2〜3文で簡潔に。";
                const reply = await callGemini(input, systemPrompt);
                output.innerText = "FUNKI: " + reply;
                output.classList.remove('hidden');
            } catch (error) {
                output.innerText = "FUNKI: 応答なし。今は騒ぎたい気分なんだ。";
                output.classList.remove('hidden');
            } finally {
                btn.disabled = false;
                btn.innerText = "✨ 問いかける";
            }
        }

        // スムーススクロールの修正：ターゲットが存在する場合のみ実行
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                const targetId = this.getAttribute('href');
                if (targetId === '#') return; // "#"のみの場合は何もしない
                
                const targetElement = document.querySelector(targetId);
                if (targetElement) {
                    e.preventDefault();
                    targetElement.scrollIntoView({
                        behavior: 'smooth'
                    });
                }
                // ターゲットが存在しない場合（例: 外部リンクやハッシュのみ）はデフォルトの挙動を維持
            });
        });

        window.addEventListener('scroll', () => {
            const scrolled = window.pageYOffset;
            const overlay = document.querySelector('.risograph-overlay');
            if (overlay) {
                overlay.style.backgroundPosition = `0 ${scrolled * 0.5}px`;
            }
        });
    </script>
</body>
</html>
